# ===========================================
# SecureExam Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control!
# ===========================================

# --- Admin Credentials ---
# Your admin login email
ADMIN_EMAIL=admin@example.com
# Bcrypt hash of your admin password. Generate with:
#   node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('your-password', 10).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=

# --- Database ---
# PostgreSQL connection string (NeonDB recommended)
# Get from: https://neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# --- Security Secrets ---
# JWT secret for admin authentication. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
# Session secret (used for cookie signing). Generate similarly:
SESSION_SECRET=

# --- AI Integration (Optional) ---
# OpenAI API key for AI-powered ID verification
# Get from: https://platform.openai.com/api-keys
# Leave empty to use manual verification fallback
OPENAI_API_KEY=

# --- Server Config ---
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
